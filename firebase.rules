rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rides/{rideId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'pickup', 'drop', 'fare', 'otp', 'status'])
        && request.resource.data.status == 'requested';
      allow update: if request.resource.data.status in ['accepted', 'started', 'completed'];
      allow delete: if true;
    }
  }
}
